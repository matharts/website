---
interface Props {
  variant: 'astronomy' | 'computation';
  class?: string;
}

const { variant, class: className } = Astro.props;
---

<div
  class:list={['spatial-backdrop', `spatial-backdrop--${variant}`, className]}
  data-spatial-backdrop={variant}
  aria-hidden="true"
>
  {variant === 'astronomy' ? (
    <div class="spatial-backdrop__scene spatial-backdrop__scene--astronomy">
      <span class="spatial-backdrop__axis spatial-backdrop__axis--horizontal"></span>
      <span class="spatial-backdrop__axis spatial-backdrop__axis--vertical"></span>
      <span class="spatial-backdrop__orbit spatial-backdrop__orbit--outer"></span>
      <span class="spatial-backdrop__orbit spatial-backdrop__orbit--middle"></span>
      <span class="spatial-backdrop__orbit spatial-backdrop__orbit--inner"></span>
      <span class="spatial-backdrop__core"></span>
    </div>
  ) : (
    <div class="spatial-backdrop__scene spatial-backdrop__scene--computation">
      <span class="spatial-backdrop__plane spatial-backdrop__plane--front"></span>
      <span class="spatial-backdrop__plane spatial-backdrop__plane--middle"></span>
      <span class="spatial-backdrop__plane spatial-backdrop__plane--back"></span>
      <span class="spatial-backdrop__node spatial-backdrop__node--one"></span>
      <span class="spatial-backdrop__node spatial-backdrop__node--two"></span>
      <span class="spatial-backdrop__node spatial-backdrop__node--three"></span>
    </div>
  )}
</div>

<style>
  .spatial-backdrop {
    display: none;
    position: absolute;
    z-index: 0;
    color: var(--color-ink-2);
    contain: layout paint;
    perspective: 52rem;
    pointer-events: none;
    user-select: none;
  }

  .spatial-backdrop__scene,
  .spatial-backdrop__orbit,
  .spatial-backdrop__plane {
    position: absolute;
    transform-style: preserve-3d;
  }

  .spatial-backdrop__scene {
    inset: 8%;
  }

  .spatial-backdrop__scene--astronomy {
    animation: spatial-orbit var(--dur-spatial) var(--ease-in-out) infinite alternate;
  }

  .spatial-backdrop__axis {
    position: absolute;
    inset-inline: 5%;
    inset-block-start: 50%;
    height: var(--rule-thin);
    background: currentColor;
    opacity: 0.64;
  }

  .spatial-backdrop__axis--vertical {
    transform: rotate(90deg);
  }

  .spatial-backdrop__orbit {
    border: var(--rule-thin) solid currentColor;
    border-radius: 50%;
  }

  .spatial-backdrop__orbit::after {
    content: "";
    position: absolute;
    inset-block-start: 50%;
    inset-inline-end: calc(var(--space-2xs) * -1);
    width: var(--space-xs);
    height: var(--space-xs);
    border: var(--rule-thin) solid currentColor;
    background: var(--color-paper);
    transform: translateY(-50%) rotate(45deg);
  }

  .spatial-backdrop__orbit--outer {
    inset: 4%;
    transform: rotate3d(1, 0, 0, 68deg) rotateZ(-18deg);
  }

  .spatial-backdrop__orbit--middle {
    inset: 17%;
    transform: rotateY(68deg) rotateZ(24deg);
  }

  .spatial-backdrop__orbit--inner {
    inset: 30%;
    transform: rotate3d(1, 0, 0, 52deg) rotateY(24deg);
  }

  .spatial-backdrop__core {
    position: absolute;
    inset-block-start: 50%;
    inset-inline-start: 50%;
    width: var(--space-md);
    height: var(--space-md);
    border: var(--rule-thin) solid currentColor;
    border-radius: 50%;
    background: var(--color-paper);
    transform: translate(-50%, -50%);
  }

  .spatial-backdrop__scene--computation {
    animation: spatial-lattice var(--dur-spatial) var(--ease-in-out) infinite alternate;
  }

  .spatial-backdrop__plane {
    inset: 10%;
    border: var(--rule-thin) solid currentColor;
    background-image:
      repeating-linear-gradient(
        90deg,
        currentColor 0 var(--rule-thin),
        transparent var(--rule-thin) var(--space-md)
      ),
      repeating-linear-gradient(
        0deg,
        currentColor 0 var(--rule-thin),
        transparent var(--rule-thin) var(--space-md)
      );
    opacity: 0.42;
  }

  .spatial-backdrop__plane--front {
    opacity: 0.68;
    transform: rotate3d(1, 0, 0, 64deg) rotateZ(45deg) translateZ(var(--space-xl));
  }

  .spatial-backdrop__plane--middle {
    opacity: 0.5;
    transform: rotate3d(1, 0, 0, 64deg) rotateZ(45deg);
  }

  .spatial-backdrop__plane--back {
    opacity: 0.32;
    transform: rotate3d(1, 0, 0, 64deg) rotateZ(45deg) translateZ(calc(var(--space-xl) * -1));
  }

  .spatial-backdrop__node {
    position: absolute;
    width: var(--space-sm);
    height: var(--space-sm);
    border: var(--rule-thin) solid currentColor;
    background: var(--color-paper);
    transform: rotate(45deg);
  }

  .spatial-backdrop__node--one {
    inset-block-start: 18%;
    inset-inline-start: 24%;
  }

  .spatial-backdrop__node--two {
    inset-block-start: 52%;
    inset-inline-end: 20%;
  }

  .spatial-backdrop__node--three {
    inset-block-end: 16%;
    inset-inline-start: 46%;
  }

  @keyframes spatial-orbit {
    from {
      transform: rotate3d(1, 0, 0, 4deg) rotateY(-4deg) rotateZ(-3deg);
    }
    to {
      transform: rotate3d(1, 0, 0, -3deg) rotateY(5deg) rotateZ(5deg);
    }
  }

  @keyframes spatial-lattice {
    from {
      transform: rotateY(-5deg) rotateZ(-2deg);
    }
    to {
      transform: rotateY(7deg) rotateZ(3deg);
    }
  }

  @media (min-width: 48rem) {
    .spatial-backdrop--astronomy {
      display: block;
    }
  }

  @media (min-width: 60rem) {
    .spatial-backdrop--computation {
      display: block;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .spatial-backdrop__scene {
      animation: none;
    }
  }
</style>
