---
import { Image } from 'astro:assets';
import avatar from '../assets/avatar.png';
import { siteContent } from '../data/site';

const navigation = siteContent.navigation;
---

<a class="skip-link" href="#main">跳到主要内容</a>

<nav class="rail" aria-label="页面索引">
  <a class="rail__brand" href="#top" aria-label="MathArts 首页" data-section-nav>MathArts</a>
  <div class="rail__links">
    {navigation.map(({ id, railLabel }) => <a href={`#${id}`} data-section-nav><span>{railLabel}</span><i aria-hidden="true"></i></a>)}
  </div>
  <button class="rail__search" type="button" data-search-trigger aria-label="检索项目 ⌘K">⌘K</button>
</nav>

<header class="mobile-head" aria-label="移动端导航">
  <a class="mobile-head__brand" href="#top"><Image src={avatar} width={40} height={40} densities={[1.5, 2]} format="webp" alt="" /><span>MathArts</span></a>
  <details class="mobile-head__menu" data-mobile-site-menu>
    <summary>菜单</summary>
    <nav aria-label="移动端页面索引">
      {navigation.map(({ id, mobileLabel }) => <a href={`#${id}`} data-section-nav>{mobileLabel}</a>)}
      <button type="button" data-search-trigger>检索项目</button>
    </nav>
  </details>
</header>

<style>
  .skip-link {
    position: fixed;
    inset-block-start: var(--space-md);
    inset-inline-start: var(--space-md);
    z-index: var(--z-tooltip);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-ink);
    color: var(--color-paper);
    transform: translateY(-180%);
    white-space: nowrap;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .rail {
    display: none;
  }

  .mobile-head {
    position: sticky;
    inset-block-start: 0;
    z-index: var(--z-sticky);
    min-height: var(--safe-mobile-header-height);
    padding-block-start: var(--safe-area-inset-block-start);
    padding-inline: var(--safe-page-gutter-inline-start) var(--safe-page-gutter-inline-end);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    border-block-end: var(--rule-thick) solid var(--color-ink);
    background: var(--color-paper);
  }

  .mobile-head__brand {
    min-height: var(--target-min);
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-wordmark);
    font-size: var(--text-lg);
    font-weight: 900;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity var(--dur-short) var(--ease-out);
  }

  .mobile-head__brand img {
    width: 2.25rem;
    height: 2.25rem;
  }

  .mobile-head__menu {
    position: relative;
  }

  .mobile-head__menu summary {
    min-width: 4rem;
    min-height: var(--target-min);
    display: flex;
    align-items: center;
    justify-content: flex-end;
    list-style: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color var(--dur-short) var(--ease-out);
  }

  .mobile-head__menu summary::-webkit-details-marker {
    display: none;
  }

  .mobile-head__menu summary::before {
    content: "\3014";
  }

  .mobile-head__menu summary::after {
    content: "\3015";
  }

  .mobile-head__menu[open] summary::before {
    content: "\300c";
  }

  .mobile-head__menu[open] summary::after {
    content: "\300d";
  }

  .mobile-head__menu nav {
    position: absolute;
    inset-block-start: calc(100% + var(--space-sm));
    inset-inline-end: 0;
    z-index: var(--z-dropdown);
    width: 18rem;
    padding: var(--space-sm);
    display: grid;
    background: var(--color-ink);
    color: var(--color-paper);
    border: var(--rule-thin) solid var(--color-paper-3);
  }

  .mobile-head__menu a,
  .mobile-head__menu button {
    min-height: var(--target-comfortable);
    padding-inline: var(--space-md);
    display: flex;
    align-items: center;
    border: 0;
    border-block-end: var(--rule-thin) solid var(--color-muted);
    background: transparent;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    white-space: nowrap;
  }

  .mobile-head__menu a[aria-current="location"] {
    background: var(--color-ink-2);
  }

  @media (hover: hover) and (pointer: fine) {
    .mobile-head__brand:hover {
      opacity: 0.68;
    }

    .mobile-head__menu summary:hover {
      background: var(--color-paper-2);
    }

    .mobile-head__menu a:hover,
    .mobile-head__menu button:hover {
      background: var(--color-ink-2);
    }

    .rail__brand:hover {
      color: var(--color-ink);
    }

    .rail__links a:hover i {
      background: var(--color-ink);
    }

    .rail__links a:hover {
      color: var(--color-ink);
    }

    .rail__search:hover {
      background: var(--color-paper-2);
    }
  }

  @media (min-width: 60rem) {
    .mobile-head {
      display: none;
    }

    .rail {
      position: fixed;
      inset-block: 0;
      inset-inline-start: 0;
      z-index: var(--z-sticky);
      width: var(--rail-width);
      padding-block: var(--safe-rail-padding-block-start) var(--safe-rail-padding-block-end);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: space-between;
      background: var(--color-paper);
      color: var(--color-ink);
      border-inline-end: var(--rule-thick) solid var(--color-ink);
    }

    .rail__brand {
      min-width: var(--target-min);
      min-height: var(--target-min);
      display: flex;
      align-items: center;
      color: var(--color-muted);
      font-family: var(--font-wordmark);
      font-weight: 900;
      text-decoration: none;
      writing-mode: vertical-rl;
      white-space: nowrap;
      transition: color var(--dur-short) var(--ease-out);
    }

    .rail__links {
      width: 100%;
      display: grid;
      gap: var(--space-sm);
    }

    .rail__links a {
      width: 100%;
      min-height: var(--target-min);
      padding-inline: var(--space-sm);
      display: grid;
      grid-template-columns: minmax(0, 1fr) var(--space-xs);
      align-items: center;
      gap: var(--space-xs);
      color: var(--color-muted);
      font-size: var(--text-xs);
      line-height: 1;
      text-decoration: none;
      transition: color var(--dur-short) var(--ease-out);
    }

    .rail__links span {
      min-width: 0;
      text-align: end;
      pointer-events: none;
      white-space: nowrap;
    }

    .rail__links a[aria-current="location"] {
      color: var(--color-ink);
      font-weight: 700;
    }

    .rail__links a:focus-visible {
      color: var(--color-ink);
    }

    .rail__links:has(a:hover, a:focus-visible)
      a[aria-current="location"]:not(:hover, :focus-visible) {
      color: var(--color-muted);
      font-weight: 400;
    }

    .rail__links i {
      width: var(--space-xs);
      height: var(--space-xs);
      border: var(--rule-thin) solid currentColor;
      transform: rotate(45deg);
      transition: background-color var(--dur-short) var(--ease-out);
    }

    .rail__brand[aria-current="location"] {
      color: var(--color-ink);
    }

    .rail__links a[aria-current="location"] i,
    .rail__links a:hover i,
    .rail__links a:focus-visible i {
      background: currentColor;
    }

    .rail__links:has(a:hover, a:focus-visible)
      a[aria-current="location"]:not(:hover, :focus-visible)
      i {
      background: transparent;
    }

    .rail__links a:active {
      transform: none;
    }

    .rail__search {
      min-width: var(--target-min);
      min-height: var(--target-min);
      border: 0;
      background: transparent;
      cursor: pointer;
      font-size: var(--text-xs);
      transition: background-color var(--dur-short) var(--ease-out);
    }
  }
</style>

<script>
  const links = [...document.querySelectorAll<HTMLAnchorElement>("[data-section-nav]")];
  const sectionIds = [...new Set(links.map(({ hash }) => hash.slice(1)).filter(Boolean))];
  const sections = sectionIds.map((id) => {
    const section = document.getElementById(id);

    if (!section) throw new Error(`[Navigation] Missing navigation target: #${id}`);
    return section;
  });
  let scrollTicking = false;

  function setCurrentSection(id: string): void {
    links.forEach((link) => {
      if (link.hash === `#${id}`) {
        link.setAttribute("aria-current", "location");
      } else {
        link.removeAttribute("aria-current");
      }
    });
  }

  function updateCurrentSection(): void {
    const marker = window.scrollY + window.innerHeight * 0.35;
    let current = sections[0];

    sections.forEach((section) => {
      if (section.offsetTop <= marker) current = section;
    });

    if (current) setCurrentSection(current.id);
    scrollTicking = false;
  }

  function requestSectionUpdate(): void {
    if (scrollTicking) return;
    scrollTicking = true;
    requestAnimationFrame(updateCurrentSection);
  }

  window.addEventListener("scroll", requestSectionUpdate, { passive: true });
  window.addEventListener("resize", requestSectionUpdate);

  links.forEach((link) => {
    link.addEventListener("click", () => {
      const id = link.hash.slice(1);
      if (id) setCurrentSection(id);
      const mobileMenu = link.closest("[data-mobile-site-menu]");
      mobileMenu?.removeAttribute("open");

      if (mobileMenu && id) {
        const targetHeading = document.getElementById(id)?.querySelector<HTMLElement>("h1, h2, h3");
        if (targetHeading) {
          targetHeading.tabIndex = -1;
          requestAnimationFrame(() => targetHeading.focus({ preventScroll: true }));
        }
      }
    });
  });

  document.querySelectorAll<HTMLElement>("[data-search-trigger]").forEach((trigger) => {
    trigger.addEventListener("click", () => {
      if (!trigger.closest("[data-interactive-site-shell]")) return;
      trigger.dispatchEvent(
        new CustomEvent("matharts:project-search-open", {
          bubbles: true
        })
      );
    });
  });

  updateCurrentSection();
</script>
