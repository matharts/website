---
import { Image } from 'astro:assets';
import avatar from '../assets/avatar.png';

interface Props {
  joined?: boolean;
}

const { joined = false } = Astro.props;
---

<footer class:list={['footer', { 'footer--joined': joined }]} aria-label="站点页脚">
  <div class="footer__brand"><Image src={avatar} width={56} height={56} format="webp" alt="" /><strong>MathArts</strong></div>
  <p>开放源码 · 公开协作 · 持续建设</p>
  <small>中国 · 二〇二六 · 各项目许可与支持范围以对应仓库为准。</small>
</footer>

<style>
  .footer {
    padding-block: clamp(var(--space-2xl), 8vw, var(--space-3xl)) var(--safe-footer-padding-block-end);
    padding-inline: var(--safe-page-gutter-inline-start) var(--safe-page-gutter-inline-end);
    display: grid;
    gap: var(--space-xl);
    background: var(--color-paper);
    color: var(--color-ink);
    border-block-start: var(--rule-thick) solid var(--color-ink);
  }

  .footer--joined {
    border-block-start: 0;
  }

  .footer__brand {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .footer__brand img {
    width: 3rem;
    height: 3rem;
  }

  .footer__brand strong {
    font-family: var(--font-wordmark);
    font-size: var(--text-3xl);
    font-weight: 900;
    line-height: 1;
  }

  .footer > p {
    max-width: var(--measure);
    margin: 0;
    color: var(--color-ink-2);
  }

  .footer > small {
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  @media (min-width: 60rem) {
    .footer {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
    }

    .footer__brand {
      grid-column: 1 / -1;
    }

    .footer > small {
      justify-self: end;
    }
  }
</style>
